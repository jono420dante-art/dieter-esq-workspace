# Option A · step 2 — copy this file to .env.deploy and fill in ( .env.deploy is gitignored )

# Dashboard: https://dash.cloudflare.com/ → pick your account → copy "Account ID" from the right sidebar (or Workers & Pages → overview).
CLOUDFLARE_ACCOUNT_ID=paste-your-32-character-account-id-here

# Create token: https://developers.cloudflare.com/fundamentals/api/get-started/create-token/
# Template: "Edit Cloudflare Workers" OR custom with: Account → Cloudflare Pages → Edit
CLOUDFLARE_API_TOKEN=paste-your-api-token-here
