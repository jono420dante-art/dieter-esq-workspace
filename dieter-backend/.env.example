# dieter-backend — copy to `.env` (do not commit `.env`).
# Frontend (Vite) vars belong in `mureka-clone/.env`, not here.

# --- FastAPI: lyrics LLMs (optional) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# DIETER_LYRICS_AI_ORDER=openai,anthropic

# --- Teal Voices (POST /api/tealvoices/sing) ---
# Optional: `pip install TTS` for Coqui; otherwise procedural / fallback.

# Optional Bark (Hugging Face suno/bark) — very heavy; GPU recommended.
# Routes: GET/POST /api/bark/*  plus tutorial-style POST /generate-vocal-layer  GET /download/{file}
# DIETER_ENABLE_BARK=1
# DIETER_BARK_MODEL=suno/bark
# DIETER_BARK_MAX_CHARS=500

# Split UI (e.g. Vercel) + API: browser origins
# DIETER_CORS_ORIGINS=https://your-app.vercel.app,http://127.0.0.1:5173

# Local mix / procedural engine (default)
# DIETER_AUDIO_ENGINE=procedural

# MusicGen / Audiocraft (large GPU RAM + multi-GB weights; `pip install audiocraft`)
# DIETER_ENABLE_MUSICGEN=1
# DIETER_MUSICGEN_MODEL=facebook/musicgen-large
# DIETER_MUSICGEN_MAX_DURATION=120
# DIETER_MUSICGEN_CFG=7.0

# Mureka cloud songs + vocals (optional)
# MUREKA_API_KEY=
# MUREKA_API_BASE=https://api.mureka.ai

# Absolute URLs in JSON (optional)
# DIETER_PUBLIC_API_ORIGIN=https://your-api.example.com

# GET /api/studio/dieter-edge — capability flags

# Optional Supabase (POST /api/song metadata)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=
# SUPABASE_SONGS_TABLE=songs

# Production-compat: POST /api/vocals | /api/music | /api/song
# DIETER_PRODUCTION_MUSIC_SEC=30
