# First tab: create (Mureka hero) | local | beatlab | voicestudio | cloud
# VITE_DEFAULT_MODE=local
VITE_DEFAULT_MODE=create

# Production / split deploy: full FastAPI base including /api (Cloudflare Pages → Railway)
# VITE_API_BASE=https://your-service.up.railway.app/api

# Beat lab (legacy override; prefer VITE_API_BASE + Connections modal)
# VITE_BEAT_API_URL=http://127.0.0.1:8000

# Vite dev proxy target (see vite.config.js)
# API_PROXY_TARGET=http://127.0.0.1:8000

# --- FastAPI: lyrics LLMs (optional; browser can also pass keys via Connections) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Prefer Claude first: DIETER_LYRICS_AI_ORDER=anthropic,openai
# DIETER_LYRICS_AI_ORDER=openai,anthropic

# --- Teal Voices (POST /api/tealvoices/sing) ---
# Optional: Coqui TTS enables speech-style acapella from lyrics. No extra env vars.
#   pip install TTS
# Without it, the route falls back to the procedural vocal stem (see response note).

# ========== FastAPI (dieter-backend) — audio, music, vocals ==========
# Split UI (e.g. Vercel) + API (Railway): allow browser origin
# DIETER_CORS_ORIGINS=https://your-app.vercel.app,http://127.0.0.1:5173

# Local mix / procedural engine (default). Optional: audiocraft stub triggers error until implemented
# DIETER_AUDIO_ENGINE=procedural

# Optional: MusicGen / Audiocraft (GPU RAM; first run downloads weights)
# DIETER_ENABLE_MUSICGEN=1
# DIETER_MUSICGEN_MODEL=facebook/musicgen-medium
# DIETER_MUSICGEN_MAX_DURATION=120

# Mureka cloud songs + vocals (optional)
# MUREKA_API_KEY=
# MUREKA_API_BASE=https://api.mureka.ai

# Public URL prefix for absolute storage links in API JSON (optional)
# DIETER_PUBLIC_API_ORIGIN=https://your-api.example.com

# --- Studio discovery (for DIETER PRO platform UI) ---
# GET /api/studio/dieter-edge — live flags for MusicGen, Mureka, Coqui, etc.
