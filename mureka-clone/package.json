{
  "name": "mureka-clone-v2",
  "private": true,
  "version": "2.0.0",
  "description": "Mureka Clone V2 — React studio (Create, Teal Voices, Local, Beat lab, Voice, V5, Cover) wired to Dieter FastAPI.",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npx vite",
    "start": "npx vite",
    "build": "npx vite build",
    "build:backend": "node scripts/build-and-sync-backend.mjs",
    "lint": "eslint .",
    "preview": "npx vite preview",
    "deploy": "node scripts/deploy-cloudflare.mjs",
    "deploy:raw": "npm run build && npx wrangler pages deploy dist --project-name=ed-geerdes"
  },
  "dependencies": {
    "@trpc/client": "^11.13.4",
    "@vercel/edge": "^1.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.5",
    "wavesurfer.js": "^7.12.4",
    "web-audio-api": "^1.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "brace-expansion": "^5.0.5"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0"
  }
}
