# FastAPI backend
PORT=8787
DIETER_AUDIO_ENGINE=procedural

# Mureka API (optional — for /api/mureka/* proxy; get key at platform.mureka.ai)
# MUREKA_API_KEY=
# MUREKA_API_BASE=https://api.mureka.ai

# First tab: create (Mureka hero) | local | beatlab | voicestudio | cloud
# VITE_DEFAULT_MODE=local
VITE_DEFAULT_MODE=create

# Production / split deploy: full FastAPI base including /api (Vercel / Cloudflare → Railway)
# VITE_API_BASE=https://your-service.up.railway.app/api
#
# Vercel (static UI): set these in Project → Settings → Environment Variables (Production + Preview)
# VITE_API_BASE=https://YOUR_BACKEND_HOST/api
# VITE_USE_TRPC=false
# Optional: override default production UI URL (see src/siteUrl.js)
# VITE_SITE_URL=https://dieter-esq-workspace.vercel.app
# Optional if you run dieter-trpc separately: VITE_TRPC_URL=https://your-trpc-host/trpc

# OpenAI (optional — for POST /api/lyrics/generate and /api/lyrics/optimize when you want AI text)
# OPENAI_API_KEY=

# tRPC gateway
DIETER_TRPC_PORT=8790
DIETER_FASTAPI_BASE=http://127.0.0.1:8787
