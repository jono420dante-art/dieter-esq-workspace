# FastAPI backend
PORT=8787
DIETER_AUDIO_ENGINE=procedural

# Mureka API (optional — for /api/mureka/* proxy; get key at platform.mureka.ai)
# MUREKA_API_KEY=
# MUREKA_API_BASE=https://api.mureka.ai

# First tab: create | local | beatlab | voicestudio | cloud
# Omit or set local = lyrics + beat (ED-GEERDES API, no Mureka). Use create for Mureka-first hero.
VITE_DEFAULT_MODE=local

# Studio branding (defaults to ED-GEERDES)
# VITE_STUDIO_NAME=ED-GEERDES
# VITE_STUDIO_SLUG=ed-geerdes
# Product line label in sidebar + Create (default: Mureka Clone V2)
# VITE_MUREKA_CLONE_LABEL=Mureka Clone V2

# Production / split deploy: full FastAPI base including /api (Vercel / Cloudflare → Railway)
# VITE_API_BASE=https://your-service.up.railway.app/api
#
# Optional: default "my gateway" URL baked into the UI when no localStorage override exists
# (users can still pin their own URL in Connections → My gateway)
# VITE_MY_GATEWAY_URL=https://your-service.up.railway.app/api
#
# Vercel (static UI): set these in Project → Settings → Environment Variables (Production + Preview)
# VITE_API_BASE=https://YOUR_BACKEND_HOST/api
# VITE_USE_TRPC=false
# Optional: override default production UI URL (see src/siteUrl.js)
# VITE_SITE_URL=https://dieter-music.app
#
# Stripe publishable (injected into dist/ed-geerdes-platform.html at build — set in Vercel/Netlify too)
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Optional if you run dieter-trpc separately: VITE_TRPC_URL=https://your-trpc-host/trpc
#
# tRPC defaults ON in vite dev (proxy) and OFF in production builds unless VITE_USE_TRPC=true

# OpenAI (optional — for POST /api/lyrics/generate and /api/lyrics/optimize when you want AI text)
# OPENAI_API_KEY=

# tRPC gateway
DIETER_TRPC_PORT=8790
DIETER_FASTAPI_BASE=http://127.0.0.1:8787
