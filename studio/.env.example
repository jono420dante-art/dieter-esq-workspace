# Public URL of the lyrics FastAPI engine (no trailing slash).
# Local Docker: http://localhost:3001
# Production: https://your-lyrics-engine.fly.dev
VITE_ENGINE_URL=http://127.0.0.1:3001

# Optional: canonical site URL for future sharing/meta
# VITE_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: Dieter FastAPI origin for /release page SEO pack (no trailing path)
# VITE_DIETER_API_BASE=https://your-api.railway.app
