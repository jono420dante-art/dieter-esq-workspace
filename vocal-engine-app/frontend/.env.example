# Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables.
# Must be the public HTTPS URL of your Vocal API (Render, Fly, etc.). No trailing slash.
#
# Example after deploying Render web service from vocal-engine-app/backend/Dockerfile:
# VITE_API_URL=https://vocal-engine-api-xxxx.onrender.com

VITE_API_URL=http://127.0.0.1:8000
